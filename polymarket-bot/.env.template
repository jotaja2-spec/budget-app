# ============================================================
# Polymarket Weather Bot — Environment Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ============================================================

# --- Trading Mode ---
# Set to "true" to run without placing real orders.
# Change to "false" only after validating paper trading output.
PAPER_TRADING=true

# --- Bankroll & Risk ---
STARTING_BANKROLL=100.0
EDGE_THRESHOLD=0.12
DAILY_LOSS_LIMIT_PCT=0.20
MAX_POSITION_SIZE_USD=15.0
MAX_OPEN_POSITIONS=5
MAX_SINGLE_TRADE_PCT=0.03
MIN_MARKET_LIQUIDITY=5000.0
KELLY_FRACTION=0.5

# --- Scan Settings ---
SCAN_INTERVAL_SECONDS=300

# --- Polymarket Credentials ---
# See README.md section "How to Get Your Polymarket Private Key"
POLY_PRIVATE_KEY=0xyour_private_key_here
POLY_API_KEY=your_api_key_here
POLY_API_SECRET=your_api_secret_here
POLY_API_PASSPHRASE=your_api_passphrase_here

# Chain ID: 137 = Polygon mainnet
POLY_CHAIN_ID=137

# --- Pushover Notifications ---
# Create app at https://pushover.net/apps/build
PUSHOVER_API_TOKEN=your_pushover_app_token_here
PUSHOVER_USER_KEY=your_pushover_user_key_here
